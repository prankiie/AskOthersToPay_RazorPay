# Server Configuration
PORT=3000

# API Configuration
API_VERSION=v1
ENV=development

# Razorpay Integration (for production)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Payment Link Configuration
PAYMENT_LINK_BASE_URL=https://razorpay.com/i

# Notification Services (for production)
SMS_SERVICE_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_account_sid
SMS_AUTH_TOKEN=your_twilio_auth_token

PUSH_NOTIFICATION_SERVICE=firebase
FIREBASE_PROJECT_ID=your_firebase_project_id

# Payment Request Configuration
PAYMENT_REQUEST_EXPIRY_MINUTES=30
MAX_PAYMENT_AMOUNT_PAISE=1000000

# Logging
LOG_LEVEL=info
